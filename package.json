{
  "name": "booratramg4",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "npm --workspace backend run start:dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "lint": "npm --workspace backend run lint && npm --workspace frontend run lint",
    "test": "npm --workspace backend run test",
    "test:backend": "npm --workspace backend run test",
    "db:generate": "npm --workspace backend run prisma:generate",
    "db:migrate": "npm --workspace backend run prisma:migrate",
    "db:deploy": "npm --workspace backend run prisma:deploy",
    "db:status": "npm --workspace backend run prisma:status",
    "infra:up": "docker compose up -d postgres redis",
    "infra:wait": "node scripts/wait-for-infra.mjs",
    "infra:down": "docker compose down",
    "bootstrap:dev": "npm run db:generate && npm run db:deploy && npm run seed",
    "seed": "npm --workspace backend run prisma:seed",
    "embeddings:backfill": "npm --workspace backend run embeddings:backfill",
    "e2e:playwright": "npm run build && npm run infra:up && npm run infra:wait && npm run db:deploy && npm run seed && playwright test",
    "prod:build": "docker compose -f docker-compose.prod.yml build",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "company:bootstrap": "npm --workspace backend run company:bootstrap"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
